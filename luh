<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShadowHub</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>

html{scroll-behavior:smooth;}

:root{
--accent:#c084fc;
--accent-strong:#8b5cf6;
--accent-glow:rgba(200,132,252,0.34);
--bg1:#07000f;
--bg2:#170025;
--bg3:#21003c;
--text:#ecedf7;
--panel:#1a0038;
--shadow:#2b0a58;
}

*{
box-sizing:border-box;
}

body{
margin:0;
font-family:'Inter',sans-serif;
min-height:100vh;
color:var(--text);
background:#080010;
overflow-x:hidden;
background-image:
radial-gradient(circle at 20% 10%, rgba(200,132,252,0.25), transparent 27%),
radial-gradient(circle at 80% 20%, rgba(139,92,246,0.25), transparent 33%),
linear-gradient(135deg, var(--bg1), var(--bg2) 45%, var(--bg3));
background-attachment:fixed;
animation:bgShift 18s ease-in-out infinite;
}

@keyframes bgShift{
0%{background-position:0% 0%;}
50%{background-position:100% 100%;}
100%{background-position:0% 0%;}
}

body:before{
content:'';
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:radial-gradient(circle at 50% 20%, rgba(134,67,255,0.16), transparent 55%);
pointer-events:none;
mix-blend-mode:screen;
}

#loader{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
background:radial-gradient(circle at 50% 40%, rgba(34,8,58,0.95), rgba(9,3,24,0.92));
backdrop-filter:blur(2px);
box-shadow:inset 0 0 60px rgba(138,98,246,0.55);
z-index:9999;
}

#loader .loader-ring{
position:relative;
width:120px;
height:120px;
border-radius:50%;
border:3px solid rgba(198,140,255,0.25);
box-shadow:0 0 25px rgba(200,132,252,0.54), inset 0 0 12px rgba(104,38,171,0.85);
}

#loader .loader-ring::after,
#loader .loader-ring::before{
content:'';
position:absolute;
left:50%;
top:50%;
transform:translate(-50%,-50%);
width:100%;
height:100%;
border-radius:50%;
border:2px solid rgba(208,158,255,0.4);
}

#loader .loader-ring::after{
width:76px;
height:76px;
}

#loader .loader-ring::before{
width:46px;
height:46px;
}

#loader .spinner{
position:absolute;
top:0;
left:50%;
width:14px;
height:100%;
background:linear-gradient(180deg, rgba(255,255,255,0.95), rgba(176,104,255,0.12));
transform-origin:center bottom;
animation:spin 1.58s linear infinite;
border-radius:999px;
box-shadow:0 0 18px rgba(240,182,255,0.95);
}

@keyframes spin{
0%{transform:translateX(-50%) rotate(0deg);}
100%{transform:translateX(-50%) rotate(360deg);}
}

#loader h2{
margin:16px 0 6px;
font-family:'Orbitron',sans-serif;
letter-spacing:0.13em;
font-size:18px;
color:#fff;
text-shadow:0 0 14px rgba(200,132,252,0.78),0 0 24px rgba(136,80,246,0.56);
}

#loader p{
font-size:13px;
opacity:0.85;
color:rgba(232,216,255,0.95);
letter-spacing:0.06em;
}

#loader .pulse-wrapper{
margin-top:16px;
display:flex;
gap:8px;
}

#loader .pulse-dot{
width:10px;
height:10px;
border-radius:50%;
background:linear-gradient(45deg, rgba(221,167,255,1), rgba(161,99,255,0.6));
box-shadow:0 0 10px rgba(200,132,252,0.8);
animation:pulse 1.2s ease-in-out infinite;
}

#loader .pulse-dot:nth-child(2){animation-delay:0.15s;}
#loader .pulse-dot:nth-child(3){animation-delay:0.3s;}

@keyframes pulse{
0%,100%{opacity:0.3;transform:scale(0.75);}
50%{opacity:1;transform:scale(1.18);}
}

nav{
position:fixed;
z-index:50;
width:100%;
top:0;
left:0;
display:flex;
justify-content:space-between;
align-items:center;
padding:16px 32px;
background:rgba(16,0,40,0.34);
backdrop-filter:blur(12px);
border-bottom:1px solid rgba(198,140,255,0.4);
box-shadow:0 10px 45px rgba(0,0,0,0.35);
}

.logo{
font-family:'Orbitron',sans-serif;
font-size:24px;
color:#e7c4ff;
letter-spacing:2px;
text-shadow:0 0 16px rgba(193,113,246,0.7);
}

nav a{
text-decoration:none;
color:#e7d3ff;
margin-left:22px;
font-weight:600;
font-size:15px;
position:relative;
padding:3px 2px;
}

nav a::after{
content:'';
position:absolute;
left:0;
bottom:-4px;
width:0;
height:2px;
background:linear-gradient(90deg, #f4c5ff, #b46af4);
transition:width 0.3s ease;
}

nav a:hover::after{width:100%;}

.hero{
min-height:72vh;
padding-top:90px;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
position:relative;
}

.hero::before{
content:'';
position:absolute;
width:420px;
height:420px;
top:15%;
left:50%;
transform:translateX(-50%);
border-radius:50%;
background:radial-gradient(circle at 50% 50%, rgba(220,150,255,0.44), transparent 58%);
filter:blur(40px);
opacity:0.95;
}

.hero h1{
font-family:'Orbitron',sans-serif;
font-size:75px;
line-height:1.1;
margin:0;
background:linear-gradient(90deg, #d0a7ff, #9872ff, #b3f8ff);
background-clip:text;
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
color:transparent;
text-shadow:0 0 18px rgba(210,150,255,0.62);
animation:textGlow 4s ease-in-out infinite;
}

.hero p{
margin-top:12px;
opacity:0.9;
font-size:20px;
max-width:650px;
color:rgba(255,246,255,0.9);
text-shadow:0 0 12px rgba(200,130,255,0.28);
}

@keyframes textGlow{
0%,100%{text-shadow:0 0 22px rgba(212,147,255,0.85);}
50%{text-shadow:0 0 32px rgba(210,159,255,1.0);}
}

.section{
padding:120px 10% 70px;
}

.section h2{
font-family:'Orbitron',sans-serif;
font-size:36px;
margin-bottom:24px;
letter-spacing:0.08em;
background:linear-gradient(90deg, #c58cff, #8765f9, #c9a7ff);
background-clip:text;
-webkit-background-clip:text;
color:transparent;
}

.categoryButtons{
display:flex;
gap:10px;
flex-wrap:wrap;
margin-bottom:24px;
}

.categoryButtons button{
background:linear-gradient(145deg, rgba(34,5,75,0.9), rgba(56,12,130,0.76));
border:1px solid rgba(203,145,255,0.5);
color:#e7e1ff;
padding:9px 15px;
border-radius:12px;
cursor:pointer;
transition:all 0.25s ease;
box-shadow:0 6px 16px rgba(90,36,171,0.26);
}

.categoryButtons button:hover,
.categoryButtons button.active{
transform:translateY(-1px);
background:linear-gradient(145deg, rgba(161,105,255,0.98), rgba(139,92,246,0.92));
border-color:rgba(239,178,255,0.95);
box-shadow:0 8px 22px rgba(185,92,255,0.48);
}

.filterBar{
display:flex;
gap:15px;
flex-wrap:wrap;
margin-bottom:36px;
}

#searchInput,#gameFilter{
min-width:160px;
padding:12px;
border-radius:10px;
border:1px solid rgba(178,147,255,0.7);
background:rgba(11,1,30,0.8);
color:white;
outline:none;
box-shadow:0 0 16px rgba(159,112,255,0.22);
}

#searchInput:focus,#gameFilter:focus{
border-color:rgba(204,130,255,1);
box-shadow:0 0 20px rgba(185,100,255,0.7);
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:28px;
}

.card{
background:linear-gradient(155deg, rgba(28,9,63,0.95), rgba(20,8,47,0.82));
border:1px solid rgba(200,125,255,0.20);
padding:28px;
border-radius:18px;
backdrop-filter:blur(12px);
box-shadow:0 12px 40px rgba(26,7,78,0.45);
transition:transform 0.45s ease, box-shadow 0.45s ease, border-color 0.45s ease;
position:relative;
opacity:0;
transform:translateY(22px) scale(0.98);
}

.card.show{
opacity:1;
transform:translateY(0) scale(1);
}

.card:hover{
transform:translateY(-10px) scale(1.01);
box-shadow:0 18px 56px rgba(137,80,255,0.42);
border-color:rgba(255,205,255,0.85);
}

.card::before{
content:'';
position:absolute;
top:-4px;
left:-4px;
right:-4px;
bottom:-4px;
border-radius:22px;
background:linear-gradient(115deg, rgba(214,147,255,0.6), rgba(137,92,250,0.25), rgba(190,150,255,0.6));
opacity:0;
transition:opacity 0.5s ease;
}

.card:hover::before{opacity:1;filter:blur(6px);}

.card h3{
font-family:'Orbitron',sans-serif;
margin-top:0;
font-size:22px;
letter-spacing:0.04em;
}

.status{
font-size:14px;
opacity:0.9;
margin-top:7px;
color:#f3e8ff;
}

.features{
font-size:14px;
opacity:0.95;
margin-top:12px;
line-height:1.4;
}

.paidBadge{
position:absolute;
top:10px;
right:10px;
background:linear-gradient(45deg,#ff4f8b,#ff56a4);
color:white;
font-size:11px;
padding:4px 8px;
border-radius:999px;
font-family:'Orbitron',sans-serif;
box-shadow:0 0 14px rgba(255,88,153,0.55);
}

.button{
display:inline-block;
margin-top:15px;
padding:11px 20px;
border-radius:10px;
border:1px solid rgba(189,139,250,0.9);
background:linear-gradient(135deg, rgba(95,50,190,0.95), rgba(161,94,255,0.42));
color:#f5e7ff;
cursor:pointer;
font-weight:600;
text-decoration:none;
transition:transform 0.2s ease, box-shadow 0.3s ease, background 0.3s ease;
}

.button:hover{
transform:translateY(-2px);
background:linear-gradient(135deg, rgba(190,120,255,0.95), rgba(156,81,255,0.9));
box-shadow:0 12px 24px rgba(173,109,255,0.45);
}

.footer{
text-align:center;
padding:50px;
opacity:0.8;
border-top:1px solid rgba(184,125,255,0.3);
font-size:13px;
}

#passwordBox,#errorModal{
display:none;
position:fixed;
top:50%;
left:50%;
transform:translate(-50%,-50%);
background:rgba(19,8,58,0.95);
border:1px solid rgba(175,117,255,0.75);
padding:32px;
border-radius:14px;
text-align:center;
z-index:10000;
width:320px;
backdrop-filter:blur(8px);
box-shadow:0 12px 26px rgba(110,35,193,0.55);
}

#errorModal{border-color:#ff6d8f;}

#passwordBox input{
background:rgba(12,2,37,0.94);
border:1px solid rgba(196,126,253,0.7);
color:white;
padding:11px;
margin-top:10px;
width:80%;
border-radius:10px;
}

#modalOverlay{
display:none;
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(7,4,18,0.88);
backdrop-filter:blur(5px);
z-index:9999;
}

.closeBtn{
position:absolute;
top:8px;
right:12px;
cursor:pointer;
opacity:0.72;
color:#ff92b7;
}

.closeBtn:hover{opacity:1;}

#checking{
margin-top:12px;
font-size:13px;
opacity:0.8;
color:#d1b8fb;
}

@keyframes shake{
0%,100%{transform:translate(-50%,-50%)}
25%{transform:translate(-55%,-50%)}
75%{transform:translate(-45%,-50%)}
}

</style>
</head>

<body>

<div id="loader">
<div class="loader-ring">
<div class="spinner"></div>
</div>
<h2>SHADOWHUB ENGINEERING</h2>
<p>Decay protocol engaging</p>
<div class="pulse-wrapper">
<div class="pulse-dot"></div>
<div class="pulse-dot"></div>
<div class="pulse-dot"></div>
</div>
</div>

<nav>
<div class="logo">SHADOW HUB</div>
<div>
<a href="#scripts">Scripts</a>
<a href="#contact">Contact</a>
</div>
</nav>

<div class="hero">
<h1>ShadowHub</h1>
<p>Premium Roblox scripting utility</p>
</div>

<div class="section" id="scripts">

<h2>Scripts</h2>

<div class="categoryButtons">
<button onclick="setCategory('all')">All</button>
<button onclick="setCategory('mm2')">MM2</button>
<button onclick="setCategory('bladeball')">Blade Ball</button>
<button onclick="setCategory('sab')">SAB</button>
<button onclick="setCategory('universal')">Universal</button>
</div>

<div id="scriptCounter">Showing scripts...</div>

<div class="filterBar">
<input type="text" id="searchInput" placeholder="Search scripts">
<select id="gameFilter">
<option value="all">All Games</option>
<option value="mm2">MM2</option>
<option value="bladeball">Blade Ball</option>
<option value="sab">SAB</option>
<option value="universal">Universal</option>
</select>
</div>

<div class="grid">

<div class="card" data-game="mm2">
<div class="paidBadge">🔒 PAID</div>
<h3>MM2 Shadow Hub</h3>
<div class="status">Status: 🟢 Undetected</div>
<div class="features">
ESP & Role Detection<br>
Gun Notifier<br>
Auto Shoot
</div>
<button class="button" onclick="openPassword('mm2')">Get Script</button>
</div>

<div class="card" data-game="sab">
<h3>Chilli Hub</h3>
<div class="status">Status: 🟢 Undetected</div>
<div class="features">
X-Ray & ESP<br>
Anti-ragdoll<br>
Infinite Jump
</div>
<a class="button" href="Chilli-Hub.html">Get Script</a>
</div>

<div class="card" data-game="bladeball">
<h3>Simple Auto Parry</h3>
<div class="status">Status: 🟢 Undetected</div>
<div class="features">
Auto Parry<br>
Keyless
</div>
<a class="button" href="Simple-AP-Bladeball.html">Get Script</a>
</div>

<div class="card" data-game="universal">
<h3>Infinite Yield</h3>
<div class="status">Status: 🟢 Undetected</div>
<div class="features">
Fly & Noclip<br>
Dark Dex<br>
Command Bar
</div>
<a class="button" href="inf-yield.html">Get Script</a>
</div>

</div>
</div>

<div class="section" id="contact">
<h2>Contact</h2>
<p>Discord: imjustthatguy1_11</p>
</div>

<div class="footer">
© 2026 ShadowHub
</div>

<div id="modalOverlay" onclick="closeAllModals()"></div>

<div id="passwordBox">
<div class="closeBtn" onclick="closeAllModals()">✖</div>
<h3 style="font-family:Orbitron">ENTER KEY</h3>
<input type="password" id="pass" placeholder="Enter security key">
<br>
<button class="button" onclick="checkPassword()">Unlock</button>
<div id="checking">Verifying...</div>
</div>

<div id="errorModal">
<h3 style="color:#ff0055;font-family:Orbitron;margin-top:0;">ACCESS DENIED</h3>
<p style="font-size:14px;color:#ff0055cc;">Invalid security key</p>
<button class="button" style="border-color:#ff0055;color:#ff0055" onclick="closeAllModals()">Retry</button>
</div>

<script>

const loaderSteps=[
"BOOT STRAP GRID",
"CALIBRATING NEON NODE",
"AMPLIFY PURPLE ECHO",
"READY FOR SHADOW MODE"
];

const loaderHeader=document.querySelector('#loader h2');
const loaderPhrase=document.querySelector('#loader p');
let loaderIndex=0;

const loaderTicker=setInterval(()=>{
if(loaderIndex<loaderSteps.length){
loaderPhrase.textContent=loaderSteps[loaderIndex];
loaderHeader.style.textShadow=`0 0 16px rgba(212,${120+loaderIndex*5},255,0.95)`;
loaderIndex++;
} else {
clearInterval(loaderTicker);
}
},750);

function finishLoader(){
const loader=document.getElementById('loader');
loader.style.opacity='0';
loader.style.transition='opacity 0.85s ease';
setTimeout(()=>{loader.style.display='none';},850);
}

setTimeout(finishLoader,3300);

let currentHub=""

function openPassword(hub){
currentHub=hub
document.getElementById("passwordBox").style.display="block"
document.getElementById("modalOverlay").style.display="block"
}

function closeAllModals(){
document.getElementById("passwordBox").style.display="none"
document.getElementById("errorModal").style.display="none"
document.getElementById("modalOverlay").style.display="none"
document.getElementById("passwordBox").classList.remove("shake")
}

async function checkPassword(){
const passwordInput=document.getElementById("pass")
const passwordBox=document.getElementById("passwordBox")
const checking=document.getElementById("checking")
checking.style.display="block"
passwordBox.classList.remove("shake")

try{
const response=await fetch("/check-password",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({hub:currentHub,password:passwordInput.value})})
const data=await response.json()

if(data.success){
sessionStorage.setItem("shadow_token",data.token)
window.location.href="shadowhub.html"
}else{
passwordBox.classList.add("shake")
setTimeout(()=>{
passwordBox.style.display="none"
document.getElementById("errorModal").style.display="block"
},400)
}

}catch(err){
alert("Backend offline")
}

checking.style.display="none"
}

const searchInput=document.getElementById("searchInput")
const gameFilter=document.getElementById("gameFilter")
const cards=document.querySelectorAll(".card")
const counter=document.getElementById("scriptCounter")

let currentCategory="all"

function setCategory(cat){
currentCategory=cat
filterScripts()
}

function filterScripts(){
let search=searchInput.value.toLowerCase()
let game=gameFilter.value
let visible=0

cards.forEach(card=>{
let title=card.querySelector("h3").innerText.toLowerCase()
let cardGame=card.getAttribute("data-game")

let matchSearch=title.includes(search)
let matchGame=game==="all"||cardGame===game
let matchCategory=currentCategory==="all"||cardGame===currentCategory

if(matchSearch&&matchGame&&matchCategory){
card.style.display="block"
visible++
}else{
card.style.display="none"
}
})

counter.innerText="Showing "+visible+" script(s)"
}

searchInput.addEventListener("input",filterScripts)
gameFilter.addEventListener("change",filterScripts)

filterScripts()

const observer=new IntersectionObserver(entries=>{
entries.forEach(entry=>{
if(entry.isIntersecting){
entry.target.classList.add("show")
}
})
})

document.querySelectorAll(".card").forEach(card=>observer.observe(card))

</script>

</body>
</html>
