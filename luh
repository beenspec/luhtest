<script>

/* LOADER */

window.setTimeout(()=>{
 document.getElementById("loader").style.display="none";
},3500);

(function(){
  // Configuration: use global variables if provided, otherwise fall back to defaults.
  // On Vercel you can set these via your hosting platform by injecting them into the page.
  // To disable the password prompt, set PASSWORD to an empty value (or "false"/"none").
  // To disable the overlay, set OVERLAY_PAGE to an empty value (or "false"/"none").
  const envPassword = (typeof window !== "undefined" && window.PASSWORD !== undefined
    ? window.PASSWORD
    : undefined) ||
    (typeof process !== "undefined" && process.env && process.env.PASSWORD !== undefined
      ? process.env.PASSWORD
      : undefined);
  const envOverlayPage = (typeof window !== "undefined" && window.OVERLAY_PAGE !== undefined
    ? window.OVERLAY_PAGE
    : undefined) ||
    (typeof process !== "undefined" && process.env && process.env.OVERLAY_PAGE !== undefined
      ? process.env.OVERLAY_PAGE
      : undefined);

  const PASSWORD = envPassword !== undefined ? envPassword : "df45d68f569707e7c5672f857f9e0b33420e97cb719d865b87b6c5e522ca5d32";
  const OVERLAY_PAGE = envOverlayPage !== undefined ? envOverlayPage : "e239cc48a359faafcc4e2f1bfeecc47b776c7cec71e1361cfc2a103356531ec8";

  const PASSWORD_ENABLED = !(envPassword === "" || envPassword === "false" || envPassword === "none");
  const OVERLAY_ENABLED = !(envOverlayPage === "" || envOverlayPage === "false" || envOverlayPage === "none");

  const RATE_KEY = "shadow_rate_limit";
  const LOCKOUT_KEY = "shadow_lockout";
  const MAX_ATTEMPTS = 5;
  const WINDOW_MS = 2 * 60 * 1000; // 2 minutes
  const LOCKOUT_MS = 2 * 60 * 1000; // 2 minutes

  const HUBS = {
    mm2: { overlay: true }
  };

  // Helper to SHA-256 hash a string into a hex digest.
  // This lets us store only the hash in the source and compare safely.
  async function sha256Hex(str) {
    const buf = new TextEncoder().encode(str);
    const hash = await crypto.subtle.digest('SHA-256', buf);
    return Array.from(new Uint8Array(hash))
      .map(b => b.toString(16).padStart(2, '0'))
      .join('');
  }

  let currentHub = "";

  function setChecking(message, show = true) {
    const el = document.getElementById("checking");
    el.textContent = message;
    el.style.display = show ? "block" : "none";
  }

  function showOverlay(show) {
    const overlay = document.getElementById("overlay");
    overlay.style.display = show ? "flex" : "none";
  }


  function getRateState() {
    try {
      const raw = localStorage.getItem(RATE_KEY);
      return raw ? JSON.parse(raw) : { attempts: [] };
    } catch {
      return { attempts: [] };
    }
  }

  function saveRateState(state) {
    localStorage.setItem(RATE_KEY, JSON.stringify(state));
  }

  function recordFailure() {
    const now = Date.now();
    const state = getRateState();
    state.attempts = (state.attempts || []).filter(ts => now - ts < WINDOW_MS);
    state.attempts.push(now);
    saveRateState(state);

    if (state.attempts.length >= MAX_ATTEMPTS) {
      localStorage.setItem(LOCKOUT_KEY, (now + LOCKOUT_MS).toString());
    }
  }

  function isLocked() {
    const lock = parseInt(localStorage.getItem(LOCKOUT_KEY) || "0", 10);
    const now = Date.now();
    if (lock && lock > now) return lock - now;
    localStorage.removeItem(LOCKOUT_KEY);
    return 0;
  }

  function resetRateLimit() {
    localStorage.removeItem(RATE_KEY);
    localStorage.removeItem(LOCKOUT_KEY);
  }

  async function loadOverlayContent() {
    if (!OVERLAY_PAGE) return "";
    try {
      const res = await fetch(OVERLAY_PAGE, { cache: "no-store" });
      if (!res.ok) throw new Error("overlay file not found");
      return await res.text();
    } catch (err) {
      console.warn("Unable to load overlay page", err);
      return "<p style='color:#ff0055'>Unable to load overlay content.</p>";
    }
  }

  async function grantAccess() {
    resetRateLimit();
    setChecking("", false);
    closePassword();

    // Grant access for overlay content and allow its scripts to run
    sessionStorage.setItem("shadow_access", "granted");

    if (!OVERLAY_ENABLED) return;

    const html = await loadOverlayContent();
    const container = document.getElementById("overlayContent");
    container.innerHTML = html;

    // Execute inline <script> blocks in the loaded HTML
    container.querySelectorAll("script").forEach(oldScript => {
      const script = document.createElement("script");
      if (oldScript.src) script.src = oldScript.src;
      if (oldScript.type) script.type = oldScript.type;
      script.textContent = oldScript.textContent;
      document.body.appendChild(script);
      document.body.removeChild(script);
    });

    showOverlay(true);
  }

  async function checkPassword() {
    if (!PASSWORD_ENABLED) {
      await grantAccess();
      return;
    }

    const lockRemaining = isLocked();
    if (lockRemaining) {
      setChecking(`Too many attempts. Try again in ${Math.ceil(lockRemaining / 1000)}s`);
      return;
    }

    setChecking("Checking key validity...");

    const password = document.getElementById("pass").value || "";
    const passwordHash = await sha256Hex(password);

    if (passwordHash === PASSWORD) {
      await grantAccess();
    } else {
      recordFailure();
      setChecking("ACCESS DENIED");
      setTimeout(() => setChecking("", false), 1200);
    }
  }

  function openPassword(hub) {
    currentHub = hub;
    if (!PASSWORD_ENABLED) {
      grantAccess();
      return;
    }

    const box = document.getElementById("passwordBox");
    if (box) {
      box.style.display = "block";
    }
    setChecking("", false);
    const passInput = document.getElementById("pass");
    if (passInput) passInput.value = "";
  }

  function closePassword() {
    const box = document.getElementById("passwordBox");
    if (box) box.style.display = "none";
  }

  function closeOverlay() {
    showOverlay(false);
  }

  // Hide UI if devtools/console opens (best-effort detection)
  let devtoolsOpen = false;
  function detectDevtools() {
    const threshold = 160;
    const widthDiff = window.outerWidth - window.innerWidth;
    const heightDiff = window.outerHeight - window.innerHeight;
    const open = widthDiff > threshold || heightDiff > threshold;
    if (open && !devtoolsOpen) {
      devtoolsOpen = true;
      closePassword();
      closeOverlay();
    }
    if (!open) {
      devtoolsOpen = false;
    }
  }

  function init() {
    const unlockBtn = document.getElementById("unlockBtn");
    const closeBtn = document.getElementById("closeBtn");
    const overlayClose = document.getElementById("overlayClose");

    if (!PASSWORD_ENABLED) {
      const box = document.getElementById("passwordBox");
      if (box) box.style.display = "none";
    }

    if (unlockBtn) unlockBtn.addEventListener("click", checkPassword);
    if (closeBtn) closeBtn.addEventListener("click", closePassword);
    if (overlayClose) overlayClose.addEventListener("click", closeOverlay);

    document.querySelectorAll("[data-hub]").forEach(el => {
      el.addEventListener("click", () => openPassword(el.dataset.hub));
    });
  }

  // Expose for inline onclick fallback
  window.openPassword = openPassword;

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

})();

/* MATRIX BACKGROUND */

const canvas = document.querySelector(".matrix");
const ctx = canvas.getContext("2d");

canvas.height = window.innerHeight;
canvas.width = window.innerWidth;

const letters = "01";
const fontSize = 14;
const columns = canvas.width / fontSize;

const drops = [];

for(let x=0;x<columns;x++) drops[x]=1;

function draw(){

ctx.fillStyle="rgba(0,0,0,0.05)";
ctx.fillRect(0,0,canvas.width,canvas.height);

ctx.fillStyle="#00ff9c";
ctx.font=fontSize+"px monospace";

for(let i=0;i<drops.length;i++){

const text = letters.charAt(Math.floor(Math.random()*letters.length));

ctx.fillText(text,i*fontSize,drops[i]*fontSize);

if(drops[i]*fontSize>canvas.height && Math.random()>0.975)
drops[i]=0;

drops[i]++;

}

}

setInterval(draw,33);

/* DEVTOOLS BLOCK */

document.addEventListener("contextmenu",function(e){
e.preventDefault();
});

document.addEventListener("keydown",function(e){

if(e.key==="F12"){e.preventDefault();}
if(e.ctrlKey && e.shiftKey && e.key==="I"){e.preventDefault();}
if(e.ctrlKey && e.shiftKey && e.key==="C"){e.preventDefault();}
if(e.ctrlKey && e.key==="U"){e.preventDefault();}

});

</script>

