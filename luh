};
const SCRIPT_HASHES = {
  mm2: "e796e073f721fc1ee6290d6707d02a4e5bc4c8c3636a908e283e38891e5bb140",
  bladeball: "daa70c37f62aee3d1f896c4e458386643dc2a46642ec7fe9c4fef25705e0be57",
