  universal: "3cc10e2bf3b270b1d40ec712ef5c8df865c72c03e827fc66cb7736a14019c300"
};
const SCRIPT_LABEL = {
  mm2: "MM2 Shadow Hub",
  bladeball: "Simple Auto Parry",
  sab: "Chilli Hub (SAB)",
  universal: "Infinite Yield"
};

const searchInput=document.getElementById("searchInput")
