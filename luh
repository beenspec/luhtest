const counter=document.getElementById("scriptCounter")

async function tokenOk(){
  const raw = sessionStorage.getItem("shadow_token_raw");
  const hashed = sessionStorage.getItem("shadow_token");
  if(!raw || !hashed) return false;
  return await sha256(raw + TOKEN_SALT) === hashed;
}

function closeRemoteHub(){
  const container=document.getElementById('remoteHubContainer');
  const content=document.getElementById('remoteHubContent');
  container.style.display='none';
  content.innerHTML='';
}

async function loadHubFromGithub(hub){
  const url = SCRIPT_RAW_URLS[hub];
  const container = document.getElementById('remoteHubContainer');
  const content = document.getElementById('remoteHubContent');
  if(!url){
    content.textContent = 'No GitHub raw URL configured for this hub.';
    container.style.display='block';
    return;
  }

  container.style.display='block';
  content.textContent = 'Loading from GitHub...' ;

  try{
    const response = await fetch(url);
    if(!response.ok) throw new Error(`Fetch failed ${response.status}`);
    const text = await response.text();
 
    content.innerHTML = text;
  }catch(err){
    content.textContent = `Unable to load remote hub content: ${err.message}`;
  }
}

function decodeScript(name){
  if(!SCRIPT_MAP[name]) return "";
  return atob(SCRIPT_MAP[name]);
}

async function showScriptMenu(hub){
  const menu = document.getElementById("scriptMenu");
  const list = document.getElementById("scriptMenuList");
  const selectedHub = hub || "all";
  document.getElementById("scriptMenuHub").textContent = "Hub: " + (SCRIPT_LABEL[selectedHub] || "All Scripts");
  list.innerHTML = "";

  const keys = selectedHub === "all" ? Object.keys(SCRIPT_MAP) : [selectedHub];
  keys.forEach(key=>{
    if(!SCRIPT_MAP[key]) return;
    const btn = document.createElement("button");
    btn.textContent = SCRIPT_LABEL[key] || key;
    btn.style.width = "100%";
    btn.style.padding = "10px";
    btn.style.border = "1px solid #c78cff";
    btn.style.background = "#140819";
    btn.style.color = "#d8b5ff";
    btn.style.cursor = "pointer";
    btn.style.marginBottom = "8px";
    btn.addEventListener("click", ()=>{
      const decoded = decodeScript(key);
      sha256(decoded).then(hash=>{
        const styleText = document.getElementById("scriptMenuCode");
        if(SCRIPT_HASHES[key] && SCRIPT_HASHES[key] !== hash){
          styleText.value = "Script integrity check failed (hash mismatch).";
          styleText.style.color = "#ff5454";
        } else {
          styleText.value = decoded;
          styleText.style.color = "#d8b5ff";
        }
      });
    });
    list.appendChild(btn);
  });

  const codeArea = document.getElementById("scriptMenuCode");
  if(keys.length === 1 && SCRIPT_MAP[keys[0]]){
    const autoValue = decodeScript(keys[0]);
    const autoHash = await sha256(autoValue);
    if(SCRIPT_HASHES[keys[0]] && SCRIPT_HASHES[keys[0]] === autoHash){
      codeArea.value = autoValue;
      codeArea.style.color = "#d8b5ff";
    } else {
      codeArea.value = "Script integrity check failed (hash mismatch).";
      codeArea.style.color = "#ff5454";
    }
  } else {
    codeArea.value = "";
    codeArea.style.color = "#d8b5ff";
  }

  menu.style.display = "block";
}

const closeScriptMenu = () => document.getElementById("scriptMenu").style.display="none";

const copyScript = () => {
  const code = document.getElementById("scriptMenuCode");
  const txt = code.value;
  if(!txt) return;

  const success = ()=>{
    const cNotify = document.getElementById("copyNotify");
    if(cNotify){
      cNotify.textContent = "Script copied";
      cNotify.style.opacity = "1";
      setTimeout(()=>{cNotify.style.opacity = "0";},1700);
    }
  };

  const fallback = () => {
    const area = document.createElement("textarea");
    area.value = txt;
    document.body.appendChild(area);
    area.select();
    try {
      document.execCommand("copy");
      success();
    } catch (e) {
      alert("Copy failed. Please copy manually.");
    }
    document.body.removeChild(area);
  };

  if(navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(txt).then(success).catch(fallback);
  } else {
    fallback();
  }
};

let currentCategory="all"

function setCategory(cat){
currentCategory=cat
filterScripts()
}

function filterScripts(){
let search=searchInput.value.toLowerCase()
let game=gameFilter.value
let visible=0

cards.forEach(card=>{
let title=card.querySelector("h3").innerText.toLowerCase()
let cardGame=card.getAttribute("data-game")

let matchSearch=title.includes(search)
let matchGame=game==="all"||cardGame===game
let matchCategory=currentCategory==="all"||cardGame===currentCategory

if(matchSearch&&matchGame&&matchCategory){
card.style.display="block"
visible++
}else{
card.style.display="none"
}
})

counter.innerText="Showing "+visible+" script(s)"
}

searchInput.addEventListener("input",filterScripts)
gameFilter.addEventListener("change",filterScripts)

filterScripts()

const observer=new IntersectionObserver(entries=>{
entries.forEach(entry=>{
if(entry.isIntersecting){
entry.target.classList.add("show")
}
})
})

document.querySelectorAll(".card").forEach(card=>observer.observe(card))

document.querySelectorAll('.script-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    const hub = btn.dataset.hub;
    if(!hub) return;

    if(hub === "mm2"){

      openPassword(hub);
    } else {
      showScriptMenu(hub);
    }
  });
});

document.getElementById('closeScriptMenu').addEventListener('click', ()=>{closeScriptMenu();});
document.getElementById('closeScriptMenu2').addEventListener('click', ()=>{closeScriptMenu();});
document.getElementById('copyScriptMenu').addEventListener('click', copyScript);

</script>

