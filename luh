/* LOADING SCREEN */

#loader{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:#000;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
z-index:9999;
font-size:20px;
}

#loader span{
opacity:0;
animation:fade 2s forwards;
}

#loader span:nth-child(2){animation-delay:1s}
#loader span:nth-child(3){animation-delay:2s}

@keyframes fade{
from{opacity:0}
to{opacity:1}
}

/* NAV */

nav{
display:flex;
justify-content:space-between;
padding:20px 40px;
background:rgba(0,0,0,0.6);
backdrop-filter:blur(8px);
border-bottom:1px solid #00ff9c33;
}

.logo{
font-family:'Orbitron', sans-serif;
font-size:22px;
letter-spacing:2px;
}

nav a{
color:#00ff9c;
text-decoration:none;
margin-left:20px;
transition:0.3s;
}

nav a:hover{
text-shadow:0 0 10px #00ff9c;
}

/* HERO */

.hero{
height:60vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
}

.hero h1{
font-size:60px;
font-family:'Orbitron';
margin:0;
text-shadow:0 0 20px #00ff9c;
animation:glow 3s infinite alternate;
}

.hero p{
opacity:0.7;
margin-top:10px;
}

@keyframes glow{
from{text-shadow:0 0 10px #00ff9c}
to{text-shadow:0 0 30px #00ff9c}
}

/* SECTION */

.section{
padding:80px 10%;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:30px;
}

/* CARD */

.card{
background:#0a0a0a;
border:1px solid #00ff9c33;
padding:25px;
border-radius:12px;
transition:0.3s;
position:relative;
overflow:hidden;
}

.card:before{
content:"";
position:absolute;
top:-100%;
left:0;
width:100%;
height:100%;
background:linear-gradient(transparent,#00ff9c55,transparent);
transition:0.5s;
}

.card:hover:before{
top:100%;
}

.card:hover{
transform:translateY(-10px) scale(1.02);
box-shadow:0 0 20px #00ff9c33;
}

.card h3{
margin-top:0;
font-family:'Orbitron';
}

/* PAID BADGE */

.paidBadge{
position:absolute;
top:12px;
right:12px;
background:#ff0055;
color:white;
font-size:11px;
padding:4px 8px;
border-radius:6px;
font-family:'Orbitron';
}

/* STATUS */

.status{
margin-top:5px;
font-size:13px;
opacity:0.8;
}

.features{
margin-top:10px;
font-size:13px;
opacity:0.85;
}

/* BUTTON */

.button{
display:inline-block;
padding:10px 18px;
border:1px solid #00ff9c;
border-radius:6px;
margin-top:15px;
text-decoration:none;
color:#00ff9c;
transition:0.3s;
cursor:pointer;
background:none;
}

.button:hover{
background:#00ff9c;
color:black;
box-shadow:0 0 10px #00ff9c;
}

/* FOOTER */

.footer{
text-align:center;
padding:40px;
opacity:0.5;
border-top:1px solid #00ff9c22;
}

/* MATRIX */

.matrix{
position:fixed;
top:0;
left:0;
z-index:-1;
}

/* PASSWORD BOX */

#passwordBox{
display:none;
position:fixed;
top:50%;
left:50%;
transform:translate(-50%,-50%);
background:#0a0a0a;
border:1px solid #00ff9c;
padding:35px;
border-radius:10px;
text-align:center;
z-index:999;
width:260px;
}

#passwordBox input{
background:black;
border:1px solid #00ff9c;
color:#00ff9c;
padding:10px;
margin-top:10px;
width:80%;
}

#passwordBox button{
margin-top:15px;
padding:10px 20px;
background:black;
border:1px solid #00ff9c;
color:#00ff9c;
cursor:pointer;
}

#passwordBox button:hover{
background:#00ff9c;
color:black;
}

.closeBtn{
position:absolute;
top:8px;
right:12px;
cursor:pointer;
font-size:18px;
}

.closeBtn:hover{
text-shadow:0 0 10px #00ff9c;
}

#checking{
margin-top:12px;
font-size:13px;
opacity:0.8;
display:none;
}

/* OVERLAY */
#overlay{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.95);
  display:none;
  justify-content:center;
  align-items:center;
  padding:30px;
  z-index:10000;
}

#overlayContent{
  max-width:960px;
  width:100%;
  background:#0a0a0a;
  border:1px solid #00ff9c;
  border-radius:14px;
  overflow:auto;
  padding:24px;
}

#overlayClose{
  position:absolute;
  top:18px;
  right:24px;
  cursor:pointer;
  font-size:24px;
  color:#00ff9c;
}

</style>
</head>

